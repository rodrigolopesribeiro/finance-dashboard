generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  WALLET
  DIGITAL
  INVESTMENT
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  POSTED
  CANCELED
}

enum CreditCardBillStatus {
  OPEN
  CLOSED
  PAID
  OVERDUE
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts        Account[]
  categories      Category[]
  transactions    Transaction[]
  creditCards     CreditCard[]
  bills           Bill[]
  cardTransactions CardTransaction[]
  goals           Goal[]
}

model Account {
  id             String      @id @default(uuid())
  userId         String
  name           String
  type           AccountType
  initialBalance Decimal     @db.Decimal(14, 2)
  currentBalance Decimal     @db.Decimal(14, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user             User          @relation(fields: [userId], references: [id])
  transactionsFrom Transaction[] @relation("AccountFrom")
  transactionsTo   Transaction[] @relation("AccountTo")

  @@index([userId])
}

model Category {
  id        String       @id @default(uuid())
  userId    String?
  name      String
  type      CategoryType
  isSystem  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user        User?        @relation(fields: [userId], references: [id])
  transactions Transaction[]
  cardTransactions CardTransaction[]

  @@index([userId])
}

model Transaction {
  id           String            @id @default(uuid())
  userId       String
  description  String
  amount       Decimal           @db.Decimal(14, 2)
  type         TransactionType
  status       TransactionStatus @default(POSTED)
  date         DateTime
  accountId    String
  toAccountId  String?
  categoryId   String?
  creditCardId String?
  billId       String?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  account    Account     @relation("AccountFrom", fields: [accountId], references: [id])
  toAccount  Account?    @relation("AccountTo", fields: [toAccountId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id])
  creditCard CreditCard? @relation("CreditCardPayments", fields: [creditCardId], references: [id])
  bill       Bill?       @relation(fields: [billId], references: [id])

  @@index([userId, date])
  @@index([accountId])
}

model CreditCard {
  id            String   @id @default(uuid())
  userId        String
  name          String
  institution   String
  limitTotal    Decimal  @db.Decimal(14, 2)
  limitAvailable Decimal @db.Decimal(14, 2)
  closingDay    Int
  dueDay        Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id])
  bills        Bill[]
  transactions CardTransaction[]
  paymentTransactions Transaction[] @relation("CreditCardPayments")

  @@index([userId])
}

model Bill {
  id           String              @id @default(uuid())
  userId       String
  creditCardId String
  month        Int
  year         Int
  closingDate  DateTime
  dueDate      DateTime
  totalAmount  Decimal             @db.Decimal(14, 2)
  paidAmount   Decimal             @db.Decimal(14, 2) @default(0)
  status       CreditCardBillStatus @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user        User       @relation(fields: [userId], references: [id])
  creditCard  CreditCard @relation(fields: [creditCardId], references: [id])
  transactions CardTransaction[]
  payments    Transaction[]

  @@unique([creditCardId, month, year])
  @@index([userId])
}

model CardTransaction {
  id           String   @id @default(uuid())
  userId       String
  creditCardId String
  billId       String
  description  String
  amount       Decimal  @db.Decimal(14, 2)
  date         DateTime
  categoryId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  creditCard CreditCard @relation(fields: [creditCardId], references: [id])
  bill       Bill       @relation(fields: [billId], references: [id])
  category   Category?  @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([creditCardId])
}

model Goal {
  id            String     @id @default(uuid())
  userId        String
  name          String
  targetAmount  Decimal    @db.Decimal(14, 2)
  currentAmount Decimal    @db.Decimal(14, 2) @default(0)
  dueDate       DateTime?
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}


